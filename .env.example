# Spotify app client ID (from https://developer.spotify.com/dashboard)
VITE_SPOTIFY_CLIENT_ID=your_client_id_here

# Optional: redirect URI after login (defaults to origin + /callback, e.g. http://127.0.0.1:3000/callback)
# Must match a Redirect URI in your Spotify app settings. Use 127.0.0.1 (not localhost) for Spotify auth.
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/callback
